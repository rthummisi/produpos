#!/usr/bin/env bash
set -euo pipefail

PRODUPOOS_ROOT="$HOME/Downloads/Projects/ProdUPOS"
BACKEND_PORT=8091
FRONTEND_PORT=5179
BACKEND_URL="http://localhost:${BACKEND_PORT}"
FRONTEND_URL="http://localhost:${FRONTEND_PORT}"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo -e "${BLUE}⚡ ProdupOS starting...${NC}"
echo ""

# Validate root
if [ ! -d "$PRODUPOOS_ROOT" ]; then
  echo "Error: ProdupOS root not found at $PRODUPOOS_ROOT"
  exit 1
fi

# Check Python
if ! command -v python3 &>/dev/null; then
  echo "Error: python3 not found. Please install Python 3.10+."
  exit 1
fi

# Check Node
if ! command -v node &>/dev/null; then
  echo "Error: node not found. Please install Node.js 18+."
  exit 1
fi

# Setup Python venv if needed
VENV="$PRODUPOOS_ROOT/.venv"
PYTHON_BIN="${PYTHON:-$(command -v python3.13 || command -v python3.12 || command -v python3.11 || command -v python3)}"
if [ ! -d "$VENV" ]; then
  echo -e "${YELLOW}Setting up Python environment...${NC}"
  "$PYTHON_BIN" -m venv "$VENV"
  "$VENV/bin/pip" install --quiet --upgrade pip
  "$VENV/bin/pip" install --quiet -r "$PRODUPOOS_ROOT/backend/requirements.txt"
  echo -e "${GREEN}✓ Backend environment ready${NC}"
else
  # Sync any newly added packages (e.g. playwright added in v2.1.0)
  "$VENV/bin/pip" install --quiet -r "$PRODUPOOS_ROOT/backend/requirements.txt" 2>/dev/null || true
fi

# Install Playwright browser (agent-browser for E2E testing) if not already present
if ! "$VENV/bin/python" -c "from playwright.sync_api import sync_playwright" &>/dev/null 2>&1; then
  echo -e "${YELLOW}Installing Playwright (E2E agent-browser)...${NC}"
  "$VENV/bin/pip" install --quiet playwright
fi
if ! "$VENV/bin/python" -c "
from playwright.sync_api import sync_playwright
with sync_playwright() as p:
    p.chromium.executable_path
" &>/dev/null 2>&1; then
  echo -e "${YELLOW}Installing Chromium browser for E2E testing...${NC}"
  "$VENV/bin/playwright" install chromium --with-deps 2>/dev/null || \
  "$VENV/bin/playwright" install chromium 2>/dev/null || true
  echo -e "${GREEN}✓ Chromium ready${NC}"
fi

# Install frontend if needed
if [ ! -d "$PRODUPOOS_ROOT/frontend/node_modules" ]; then
  echo -e "${YELLOW}Installing frontend dependencies...${NC}"
  cd "$PRODUPOOS_ROOT/frontend"
  npm install --silent
  echo -e "${GREEN}✓ Frontend dependencies ready${NC}"
fi

# Kill existing processes on our ports
lsof -ti:${BACKEND_PORT} | xargs kill -9 2>/dev/null || true
lsof -ti:${FRONTEND_PORT} | xargs kill -9 2>/dev/null || true
sleep 0.5

# Start backend
cd "$PRODUPOOS_ROOT"
mkdir -p "$PRODUPOOS_ROOT/backend/app/logs"
PYTHONPATH="$PRODUPOOS_ROOT" \
  "$VENV/bin/uvicorn" backend.app.main:app \
  --host 0.0.0.0 \
  --port "$BACKEND_PORT" \
  --log-level warning \
  >> "$PRODUPOOS_ROOT/backend/app/logs/backend.log" 2>&1 &
BACKEND_PID=$!

# Wait for backend
echo -n "  Waiting for backend"
for i in {1..20}; do
  if curl -sf "$BACKEND_URL/health" &>/dev/null; then
    echo ""
    echo -e "${GREEN}✓ Backend:  ${BACKEND_URL}${NC}"
    break
  fi
  echo -n "."
  sleep 0.5
done

# Start frontend
cd "$PRODUPOOS_ROOT/frontend"
npm run dev >> "$PRODUPOOS_ROOT/backend/app/logs/frontend.log" 2>&1 &
FRONTEND_PID=$!

# Wait for frontend
echo -n "  Waiting for frontend"
for i in {1..20}; do
  if curl -sf "$FRONTEND_URL" &>/dev/null; then
    echo ""
    echo -e "${GREEN}✓ Frontend: ${FRONTEND_URL}${NC}"
    break
  fi
  echo -n "."
  sleep 0.5
done

echo ""
echo -e "${BLUE}Opening ProdupOS UI...${NC}"
echo ""

# Open browser
if command -v open &>/dev/null; then
  open "$FRONTEND_URL"
elif command -v xdg-open &>/dev/null; then
  xdg-open "$FRONTEND_URL"
fi

echo -e "  Backend PID:  ${BACKEND_PID}"
echo -e "  Frontend PID: ${FRONTEND_PID}"
echo ""
echo -e "  Logs: ${PRODUPOOS_ROOT}/backend/app/logs/"
echo ""

# Wait for guardian scan then show summary
echo -n "  Guardian scan"
for i in {1..30}; do
  GUARDIAN=$(curl -sf "${BACKEND_URL}/health" 2>/dev/null | python3 -c "import json,sys; h=json.load(sys.stdin); g=h.get('guardian',{}); print('ready' if g.get('ready') else 'pending')" 2>/dev/null)
  if [ "$GUARDIAN" = "ready" ]; then
    echo ""
    SUMMARY=$(curl -sf "${BACKEND_URL}/health" 2>/dev/null | python3 -c "
import json,sys
h=json.load(sys.stdin)
g=h.get('guardian',{})
parts=[]
if g.get('new_products',0)>0: parts.append(f\"{g['new_products']} new product(s)\")
if g.get('versions_synced',0)>0: parts.append(f\"{g['versions_synced']} version(s) synced\")
if g.get('tags_created',0)>0: parts.append(f\"{g['tags_created']} tag(s) created\")
if g.get('changelogs_created',0)>0: parts.append(f\"{g['changelogs_created']} changelog(s) created\")
if g.get('errors',0)>0: parts.append(f\"{g['errors']} error(s)\")
print(', '.join(parts) if parts else 'all products clean')
" 2>/dev/null)
    echo -e "${GREEN}✓ Guardian:${NC} ${SUMMARY}"
    break
  fi
  echo -n "."
  sleep 1
done
echo ""
echo -e "  Press ${YELLOW}Ctrl+C${NC} to stop ProdupOS"
echo ""

# Trap to cleanup on exit
cleanup() {
  echo ""
  echo -e "${YELLOW}Stopping ProdupOS...${NC}"
  kill "$BACKEND_PID" "$FRONTEND_PID" 2>/dev/null || true
  lsof -ti:${BACKEND_PORT} | xargs kill -9 2>/dev/null || true
  lsof -ti:${FRONTEND_PORT} | xargs kill -9 2>/dev/null || true
  echo -e "${GREEN}Stopped.${NC}"
}
trap cleanup EXIT INT TERM

# Keep alive
wait
